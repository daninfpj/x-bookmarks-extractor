# Get these from browser devtools:
# Open x.com/bookmarks → DevTools → Network tab → filter "Bookmarks" → click the request
#
# X_BEARER_TOKEN: Request Headers → Authorization (strip the "Bearer " prefix)
# X_AUTH_TOKEN:   Request Headers → Cookie → find "auth_token=<value>"
# X_CSRF_TOKEN:   Request Headers → x-csrf-token  (same as the "ct0" cookie value)

X_BEARER_TOKEN=""
X_AUTH_TOKEN=""
X_CSRF_TOKEN=""

# Required for `bun run summarize` (link summarisation agent)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=""
